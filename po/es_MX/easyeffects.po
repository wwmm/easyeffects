#: src/autostart.cpp:92
msgid ""
"Cannot enable autostart option because background access has been denied. "
"Please allow \"Run in Background\" permission for Easy Effects in your "
"system app settings."
msgstr ""
"No se pudo activar el inicio automático porque el acceso en segundo plano "
"está restringido por el sistema. Permite que Easy Effects se ejecute en "
"segundo plano desde la configuración del sistema."

#: src/command_line_parser.cpp:44
msgid "Quit Easy Effects. Useful when running in service mode."
msgstr "Salir de Easy Effects. Útil cuando se ejecuta en modo de servicio."

#: src/command_line_parser.cpp:45
msgid "Reset Easy Effects."
msgstr "Reiniciar Easy Effects."

#: src/command_line_parser.cpp:46
msgid "Hide the window."
msgstr "Esconder ventana."

#: src/command_line_parser.cpp:48
msgid ""
"Global bypass. 1 to enable, 2 to disable and 3 to get the current state."
msgstr ""
"Supresión global (desactivar todos los efectos). 1 para habilitar, 2 para "
"deshabilitar y 3 para mostrar el estado actual."

#: src/command_line_parser.cpp:49
msgid "bypass-state"
msgstr "Estado de supresión"

#: src/command_line_parser.cpp:50
msgid "Toggle the state of the global bypass."
msgstr "Activar o desactivar la supresión global."

#: src/command_line_parser.cpp:51
msgid "Load a preset. Example: easyeffects -l music"
msgstr "Cargar un perfil. Ejemplo: easyeffects -l music"

#: src/command_line_parser.cpp:51
msgid "preset-name"
msgstr "Nombre del perfil"

#: src/command_line_parser.cpp:52
msgid "Show available presets."
msgstr "Mostrar perfiles disponibles."

#: src/command_line_parser.cpp:53
msgid "Get the last loaded input/output preset."
msgstr "Mostrar el último perfil de entrada/salida cargado."

#: src/command_line_parser.cpp:53
msgid "preset-type"
msgstr "Tipo de perfil"

#: src/command_line_parser.cpp:54
msgid "Get the last loaded input and output presets."
msgstr "Mostrar los últimos perfiles de entrada y salida cargados."

#: src/command_line_parser.cpp:55
msgid "Deprecated. Use --service-mode instead."
msgstr "En desuso. Usa --service-mode en su lugar."

#: src/command_line_parser.cpp:56
msgid "Start the application with service mode turned on."
msgstr "Iniciar la aplicación en modo de servicio."

#: src/command_line_parser.cpp:57
msgid "Enable debug messages."
msgstr "Activar registros de depuración."

#: src/command_line_parser.cpp:127
msgid "Must specify preset type: input/output."
msgstr "Debes especificar el tipo de perfil: entrada/salida."

#: src/command_line_parser.cpp:162
msgid "Output presets"
msgstr "Perfiles de salida"

#: src/command_line_parser.cpp:164
msgid "No output presets."
msgstr "No hay perfiles de salida."

#: src/command_line_parser.cpp:175
msgid "Input presets"
msgstr "Perfiles de entrada"

#: src/command_line_parser.cpp:177
msgid "No input presets."
msgstr "No hay perfiles de entrada."

#: src/command_line_parser.cpp:207
msgid "Specified preset does not exist."
msgstr "Este perfil no existe."

#: src/command_line_parser.cpp:227
msgid "Provided an invalid bypass state."
msgstr "Ingresaste un estado de supresión inválido."

